rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function treeData(treeId) {
      return get(/databases/$(database)/documents/trees/$(treeId)).data;
    }

    function isMember(treeId) {
      return isSignedIn() && request.auth.uid in treeData(treeId).memberIds;
    }

    function isEditor(treeId) {
      let t = treeData(treeId);
      return isSignedIn() && (request.auth.uid == t.ownerId || request.auth.uid in t.editorIds);
    }

    function isOwner(treeId) {
      return isSignedIn() && request.auth.uid == treeData(treeId).ownerId;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid);
    }

    match /trees/{treeId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.auth.uid in request.resource.data.editorIds;

      // Updates: owner can change anything. Editors can update content fields
      // but cannot edit membership arrays.
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId
        || (
          request.auth.uid in resource.data.editorIds
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.memberIds == resource.data.memberIds
          && request.resource.data.editorIds == resource.data.editorIds
          && request.resource.data.viewerIds == resource.data.viewerIds
        )
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;

      match /members/{memberUid} {
        allow read: if isMember(treeId);
        // Only the owner manages membership directly.
        allow write: if isOwner(treeId);
      }

      match /persons/{personId} {
        allow read: if isMember(treeId);
        allow write: if isEditor(treeId);
      }

      match /relations/{relationId} {
        allow read: if isMember(treeId);
        allow write: if isEditor(treeId);
      }

      match /history/{historyId} {
        allow read: if isMember(treeId);
        allow create: if isEditor(treeId);
        allow update, delete: if false;
      }
    }

    // Share links - tightened in Phase 8.
    match /shareLinks/{code} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
