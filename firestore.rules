rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Authenticated users may create/maintain their own profile document.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid);
    }

    // Tree-level access is gated by the memberIds array on the tree document.
    // Subcollection rules and role-aware writes are tightened in Phase 3.
    match /trees/{treeId} {
      function isMember() {
        return isSignedIn()
          && resource != null
          && request.auth.uid in resource.data.memberIds;
      }

      allow read: if isMember();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update, delete: if isMember();

      match /{subcollection}/{docId} {
        allow read, write: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/trees/$(treeId)).data.memberIds;
      }
    }

    // Public share links - Phase 8 will refine to read-only and per-link scoping.
    match /shareLinks/{code} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
